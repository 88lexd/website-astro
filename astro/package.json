		"slugify": "^1.6.9",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "4.3.1",
		"typescript": "^6.0.3"
	},
	"lint-staged": {
		"*.{astro,js,jsx,ts,tsx,md,mdx,json}": [
			"prettier --write --plugin-search-dir=."
